# ──────────────────────────────────────────────────────────────
# CompetencyFolio v3 — Environment Variables
# Copy this file to .env.local for local development
# Add these same variables in Vercel → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────

# ─── DATABASE (Vercel Postgres) ────────────────────────────────
# Get these from: Vercel Dashboard → Storage → Create Database → Postgres
# After creating the database, Vercel auto-populates these in your project
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── AUTHENTICATION ───────────────────────────────────────────
# Generate a strong random secret: openssl rand -base64 32
JWT_SECRET="your-secret-key-change-this-in-production"

# ─── APP URL (optional, used for share links) ─────────────────
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
